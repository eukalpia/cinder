{
  "name": "docs-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/prepare-site.mjs --skip-compile && next dev",
    "prepare:site": "node scripts/prepare-site.mjs",
    "build": "node scripts/prepare-site.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:routes": "node scripts/verify-export.mjs",
    "test:examples": "node scripts/prepare-site.mjs",
    "test:visual": "echo \"Visual regression runs in the Pages browser workflow.\""
  },
  "dependencies": {
    "fumadocs-core": "^16.3.2",
    "fumadocs-mdx": "^14.2.2",
    "fumadocs-ui": "^16.3.2",
    "lucide-react": "^0.562.0",
    "next": "16.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
