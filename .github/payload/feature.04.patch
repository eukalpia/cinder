+    super.key,
+    required this.properties,
+    this.nameWidth = 24,
+    this.emptyMessage = 'No properties',
+  });
+
+  final List<PropertyEntry> properties;
+  final double nameWidth;
+  final String emptyMessage;
+
+  @override
+  Widget build(BuildContext context) {
+    if (properties.isEmpty) {
