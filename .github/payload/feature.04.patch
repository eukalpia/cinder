+                    softWrap: false,
+                    maxLines: 1,
+                    overflow: TextOverflow.ellipsis,
+                  ),
+                ),
+                const Text(' '),
+                Expanded(
+                  child: property.editable && property.onChanged != null
+                      ? _EditablePropertyValue(
+                          value: property.value,
+                          onChanged: property.onChanged!,
+                        )
