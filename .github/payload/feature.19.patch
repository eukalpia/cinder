+        '\x1b_Gf=100;AAAA\x1b\\',
+        '\x1bPq"1;1;1;1#0;2;0;0;0~\x1b\\',
+      ].join('\n');
+
+      final output = TerminalTextSanitizer.sanitize(input);
+
+      expect(output.contains('\x1b'), isFalse);
