+  Widget _row(T row, int index) {
+    Widget child = Row(
+      children: [
+        for (final column in columns) _cell(column, column.valueBuilder(row)),
+      ],
+    );
+    if (selectedIndex == index) {
+      child = Container(
+        color: selectedColor ?? const Color.fromRGB(43, 49, 67),
+        child: child,
